@page "/"
@rendermode InteractiveServer
@inject App_menstrual.Models.AppService AppState
@inject NavigationManager NavManager

<PageTitle>Inicio</PageTitle>

<div class="container mt-4">
    <h1>¡Bienvenida a tu App Menstrual! 🌸</h1>
    <p>Completa tus datos para empezar a llevar tu registro.</p>

    <div class="card p-4 mt-4 shadow-sm border-0 bg-light">
        <h3>Tu Perfil</h3>

        <div class="mb-3 mt-3">
            <label class="form-label">¿Cómo te llamas?</label>
            <input class="form-control" @bind="AppState.Usuario.Nombre" placeholder="Ej. Ana" />
        </div>

        <div class="mb-3">
            <label class="form-label">Duración promedio de tu ciclo (en días):</label>
            <input type="number" class="form-control" @bind="AppState.Usuario.DuracionCicloPromedio" />
        </div>

        <hr />

        <h4>Registrar Periodo</h4>
        <div class="mb-3">
            <label class="form-label">Selecciona el primer día de sangrado:</label>
            <input type="date" class="form-control" @bind="nuevaFecha" />
        </div>

        <div class="d-flex gap-2 mt-4">
            <button class="btn btn-primary" @onclick="GuardarYRegistrar">
                Guardar Registro
            </button>

            <button class="btn btn-outline-secondary" @onclick="IrAlCalendario">
                Ver mi Calendario 📅
            </button>
        </div>
    </div>

    @if (mostrarMensaje)
    {
        <div class="alert alert-success mt-4">
            ¡Registro guardado exitosamente! 🩸
        </div>
    }
</div>

@code {
    // Variable temporal para el selector de fecha
    private DateTime nuevaFecha = DateTime.Today;
    private bool mostrarMensaje = false;

    private void GuardarYRegistrar()
    {
        // Llamamos al método que programaste en AppService
        AppState.RegistrarPeriodo(nuevaFecha);

        // Mostramos el mensaje de éxito
        mostrarMensaje = true;
    }

    private void IrAlCalendario()
    {
        // Navegamos mágicamente a la otra página
        NavManager.NavigateTo("/calendario");
    }
}